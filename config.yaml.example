# KoeRelay 設定サンプル。config.yaml にコピーして編集してください。
# すべて任意。書かなかった項目は既定値が使われます。

stt:
  enabled: true
  # backend: faster-whisper(ローカルCPU/NVIDIA) | remote(WSL等のSTTサーバ, AMD GPU可)
  # AMD(ROCm)GPUで文字起こししたい場合は remote(stt_server/)を使う。faster-whisperは
  # CTranslate2依存でROCm非対応のため、その構成ではCPUになる。
  backend: remote
  remote_url: http://127.0.0.1:8099/v1   # remote時: STTサーバ(OpenAI互換)
  # STTサーバの自動起動(remote時)。WSL(Ubuntu-24.04)で起動する例。
  # 既存の Irodori-TTS-Server の .venv(torch-rocm/transformers入り)を再利用する:
  autostart_server: true
  server_cmd: ["wsl","-d","Ubuntu-24.04","--","bash","-lc","cd ~/github/KoeRelay/stt_server && KOERELAY_STT_VENV=~/github/KoeRelay/Irodori-TTS-Server/.venv ./start.sh"]
  # stop_cmd: 未指定ならwsl起動時は自動で pkill -f 'uvicorn server:app'
  # --- 以下は backend: faster-whisper(ローカル)時の設定 ---
  model: small            # tiny/base/small/medium/large-v3。大きいほど高精度・低速
  device: auto            # auto(GPU優先→失敗時CPU) | cuda | cpu
  compute_type: float16   # cuda:float16 / cpu は自動で int8 に補正
  language: ja
  samplerate: 16000
  min_record_sec: 0.3     # これ未満の短い押下/発話は誤爆として無視
  mode: ptt               # ptt(ホットキー長押し) | vad(常時リスニング)。トレイからも切替可
  vad_aggressiveness: 2   # 0-3。大きいほど発話判定が厳しい(雑音に強い)
  vad_silence_ms: 600     # この無音で発話区間を確定(短いほど低遅延・誤爆増)
  vad_ignore_while_speaking: true  # 発話中(TTS再生中)は取り込まない(エコー防止)

tts:
  enabled: true
  base_url: http://127.0.0.1:8088/v1   # Irodori-TTS-Server
  api_key: irodori
  model: irodori-tts
  voice: sumire           # 参照音声(TTSサーバ側に登録した voice 名)
  speed: 1.0
  response_format: wav
  # サーバ自動起動(任意)。true にすると KoeRelay 起動時に下の server_cmd で
  # TTSサーバを立ち上げ、終了時に自動停止します(自分で起動したときのみ pkill)。
  # 既に起動済みのサーバがあればそれを使い、二重起動も勝手な停止もしません。
  autostart_server: true
  # WSL(Ubuntu-24.04)上のサーバを起動する例。distro 名は `wsl -l -q` で確認:
  server_cmd: ["wsl","-d","Ubuntu-24.04","--","bash","-lc","cd ~/github/KoeRelay/Irodori-TTS-Server && ./start.sh"]
  # 終了時の停止コマンド(未指定なら wsl 起動時は自動で pkill -f irodori_openai_tts):
  # stop_cmd: ["wsl","-d","Ubuntu-24.04","--","bash","-lc","pkill -f irodori_openai_tts"]
  warmup: true            # 起動時にダミー合成して初回発話を速くする

audio:
  output_device: "CABLE"  # 仮想マイク側の出力(部分一致)。VB-CABLE の "CABLE Input"
  monitor_enabled: false  # 実スピーカーへも同時再生してモニタするか
  monitor_device: ""      # 空なら OS 既定の出力
  input_device: ""        # 録音マイク(部分一致)。空なら既定マイク
  volume: 1.0

hotkey:
  enabled: true
  key: "<f8>"             # 長押しで録音。組み合わせ例: "<ctrl>+<alt>+k"

update:
  auto_check: true        # 起動時に GitHub Releases を確認
  auto_install: true      # true: モデル/サーバ読込前に自動DL+適用+再起動(.exe時)
  repo: liasvistreamgamemusic-sketch/KoeRelay
